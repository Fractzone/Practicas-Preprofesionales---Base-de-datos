    E_formulario2 [shape=box, style="bold,filled", fillcolor="#cfe8ff", label="FORMULARIO2"];
    A_formulario2__pk [shape=ellipse, label=<<U>id_formulario2</U>>];
    E_formulario2 -- A_formulario2__pk;
    A_formulario2_0 [shape=ellipse, label="fecha_real_inicio"];
    E_formulario2 -- A_formulario2_0;
    A_formulario2_1 [shape=ellipse, label="fecha_real_fin"];
    E_formulario2 -- A_formulario2_1;
    A_formulario2_2 [shape=ellipse, label="horas_cumplidas"];
