    A_tutor_empresarial_5 [shape=ellipse, label="cargo"];
    E_tutor_empresarial -- A_tutor_empresarial_5;
    A_tutor_empresarial_6 [shape=ellipse, label="ruc_empresa (UNIQUE)"];
    E_tutor_empresarial -- A_tutor_empresarial_6;
    A_tutor_empresarial_7 [shape=ellipse, label="nombre_empresa"];
    E_tutor_empresarial -- A_tutor_empresarial_7;
    A_tutor_empresarial_8 [shape=ellipse, label="direccion_empresa"];
