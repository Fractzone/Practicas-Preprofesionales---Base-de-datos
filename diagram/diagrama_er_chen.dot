// Diagrama Entidad-Relacion (notacion de Peter Chen)
// Render: dot -Tpng diagrama_er_chen.dot -o diagrama_er_chen.png
//   o pegarlo en https://dreampuf.github.io/GraphvizOnline
graph ER {
    layout=neato;
    overlap=false;
    splines=true;
    sep="+12";
    node [fontname="Segoe UI", fontsize=10];
    edge [fontname="Segoe UI", fontsize=9, dir=none];

    E_administrador [shape=box, style="bold,filled", fillcolor="#cfe8ff", label="ADMINISTRADOR"];
    A_administrador__pk [shape=ellipse, label=<<U>usuario</U>>];
    E_administrador -- A_administrador__pk;
    A_administrador_0 [shape=ellipse, label="contrasena"];
    E_administrador -- A_administrador_0;
    A_administrador_1 [shape=ellipse, label="email"];
    E_administrador -- A_administrador_1;
    A_administrador_2 [shape=ellipse, label="eliminado"];
    E_administrador -- A_administrador_2;

    E_login [shape=box, style="bold,filled", fillcolor="#cfe8ff", label="LOGIN"];
    A_login__pk [shape=ellipse, label=<<U>identificador</U>>];
    E_login -- A_login__pk;
    A_login_0 [shape=ellipse, label="contrasena"];
    E_login -- A_login_0;
    A_login_1 [shape=ellipse, label="rol"];
    E_login -- A_login_1;
    A_login_2 [shape=ellipse, label="eliminado"];
    E_login -- A_login_2;

    E_estudiante [shape=box, style="bold,filled", fillcolor="#cfe8ff", label="ESTUDIANTE"];
    A_estudiante__pk [shape=ellipse, label=<<U>cedula</U>>];
