    A_estudiante_0 [shape=ellipse, label="contrasena"];
    E_estudiante -- A_estudiante_0;
    A_estudiante_1 [shape=ellipse, label="apellidos"];
    E_estudiante -- A_estudiante_1;
    A_estudiante_2 [shape=ellipse, label="nombres"];
    E_estudiante -- A_estudiante_2;
    A_estudiante_3 [shape=ellipse, label="telefono"];
    E_estudiante -- A_estudiante_3;
    A_estudiante_4 [shape=ellipse, label="email"];
    E_estudiante -- A_estudiante_4;
    A_estudiante_5 [shape=ellipse, label="carrera"];
    E_estudiante -- A_estudiante_5;
    A_estudiante_6 [shape=ellipse, label="ciclo"];
    E_estudiante -- A_estudiante_6;
