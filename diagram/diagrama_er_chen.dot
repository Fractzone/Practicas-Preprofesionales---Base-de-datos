    A_coordinador_vinculacion__pk [shape=ellipse, label=<<U>cedula</U>>];
    E_coordinador_vinculacion -- A_coordinador_vinculacion__pk;
    A_coordinador_vinculacion_0 [shape=ellipse, label="contrasena"];
    E_coordinador_vinculacion -- A_coordinador_vinculacion_0;
    A_coordinador_vinculacion_1 [shape=ellipse, label="nombres"];
